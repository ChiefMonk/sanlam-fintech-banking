{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "SanlamBank": {
    "EnableOpenTelemetry": false,
    "OpenTelemetry": {
      "Url": "https://otel.sanlam:5000",
      "EndpointType": "Grpc",
      "SamplingType": "TraceIdRatio",
      "SamplingRatio": 0.2
    },
    "Redis": {
      "ConnectionString": "127.0.0.1:6379",
      "Options": {
        "BreakInMs": 5000,
        "SleepInMs": 200,
        "ExceptionsBeforeBreaking": 5,
        "RetryCount": 3
      }
    },
    "Sql": {
      "BankConnection": "ms-sql-1.connection.sanlam",
      "OtherConnection": "ms-sql-2.connection.sanlam"
    },
    "NoSql": {
      "BankConnection": "no-sql-1.connection.sanlam",
      "OtherConnection": "no-sql-2.connection.sanlam"
    },
    "Kafka": {
      "Hostname": "127.0.0.1:123",
      "Password": "sanlam",
      "TopicSignificantEvents": "significant.events.test",
      "TopicWithdrawalEvents": "withdrawal.events.test",
      "TopicOtherUsefulEvents": "other.events.test"
    },
    "RabbitMQ": {
      "Hostname": "127.0.0.1:124",
      "Username": "sanlam",
      "Password": "sanlam",
      "ExchangeSignificantEvents": "significant.events.exchange.test",
      "RoutingKeySignificantEvents": "significant.events.routingkey.test",
      "ExchangeWithdrawalEvents": "withdrawal.events.exchange.test",
      "RoutingKeyWithdrawalEvents": "withdrawal.events.routingkey.test",
      "ExchangeOtherUsefulEvents": "other.events.exchange.test",
      "RoutingKeyOtherUsefulEvents": "other.events.routingkey.test"
    }

  }
}
